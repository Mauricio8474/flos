# PostgreSQL
POSTGRES_USER=flos_admin
POSTGRES_PASSWORD=change_this_password
POSTGRES_DB=flos_core

# Database URL — Docker: flos-db host, Local: localhost
# Para Docker:
DATABASE_URL=postgresql+psycopg://flos_admin:change_this_password@flos-db:5432/flos_core
# Para desarrollo local (sin Docker):
# DATABASE_URL=postgresql+psycopg://flos_admin:change_this_password@localhost:5432/flos_core

# JWT secret — cambiar en producción
JWT_SECRET=change-this-secret-in-production

# Puerto de la app
APP_PORT=8001
